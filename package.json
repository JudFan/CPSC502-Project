{
  "name": "textScan",
  "displayName": "textScan",
  "description": "Get highlighted text from VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {"command": "textScan.helloWorld", "title": "Hello World"},
      {"command": "textScan.toggleSidebar", "title": "Toggle TextScan Sidebar"}
    ],
    "keybindings": [
        {
            "command": "textScan.helloWorld",
            "key": "numpad1",
            "when": "editorTextFocus"
        },
        {
            "command": "textScan.toggleSidebar",
            "key": "numpad2",
            "when": "editorTextFocus"
        }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
